generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  NEW
  READY_FOR_IMPLEMENTATION
  IN_PROGRESS
  READY_FOR_ACCEPTANCE
  DONE
}

enum TicketType {
  BUG
  FEATURE
  FIX
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String
  password  String
  createdAt DateTime     @default(now())

  // Email verification: new accounts start unverified and cannot log in
  // until they confirm via the link emailed at sign-up. Token expires in 24h.
  emailVerified             Boolean   @default(false)
  verificationToken         String?   @unique
  verificationTokenExpiresAt DateTime?

  memberships     TeamMember[]
  createdTickets  Ticket[]     @relation("CreatedTickets")
  assignedTickets Ticket[]     @relation("AssignedTickets")
}

model Team {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())

  members TeamMember[]
  tickets Ticket[]
  epics   Epic[]
}

model Epic {
  id          String   @id @default(cuid())
  teamId      String
  title       String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@index([teamId])
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     String   @default("member") // "admin" | "member"
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Ticket {
  id          String       @id @default(cuid())
  title       String
  description String       @default("")
  status      TicketStatus @default(NEW)
  type        TicketType   @default(FEATURE)
  position    Int          @default(0)
  teamId      String
  epicId      String?
  createdById String
  assigneeId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  team      Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  epic      Epic? @relation(fields: [epicId], references: [id], onDelete: SetNull)
  createdBy User  @relation("CreatedTickets", fields: [createdById], references: [id])
  assignee  User? @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([epicId])
}
